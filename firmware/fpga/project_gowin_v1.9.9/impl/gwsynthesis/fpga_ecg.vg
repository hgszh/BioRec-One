module fifo_16 (
  ecg_r_pulse,
  rr_fifo_read_en_Z,
  clk_xtal_27_d,
  n425_14,
  ecg_rr_interval,
  rr_fifo_empty,
  rr_fifo_out,
  rr_fifo_cnt
)
;
input ecg_r_pulse;
input rr_fifo_read_en_Z;
input clk_xtal_27_d;
input n425_14;
input [11:0] ecg_rr_interval;
output rr_fifo_empty;
output [15:0] rr_fifo_out;
output [3:0] rr_fifo_cnt;
wire VCC;
wire GND;
  \~fifo_sc.fifo_16  fifo_sc_inst (
    .ecg_r_pulse(ecg_r_pulse),
    .rr_fifo_read_en_Z(rr_fifo_read_en_Z),
    .clk_xtal_27_d(clk_xtal_27_d),
    .n425_14(n425_14),
    .ecg_rr_interval(ecg_rr_interval[11:0]),
    .rr_fifo_empty(rr_fifo_empty),
    .rr_fifo_out(rr_fifo_out[15:0]),
    .rr_fifo_cnt(rr_fifo_cnt[3:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* fifo_16 */
module SPI_Slave (
  spi_sclk_d,
  spi_mosi_d,
  clk_xtal_27_d,
  n425_14,
  tx_valid,
  spi_cs_d,
  data_send,
  rx_valid,
  CS_Det,
  w_SPI_MISO_Mux,
  data_recv
)
;
input spi_sclk_d;
input spi_mosi_d;
input clk_xtal_27_d;
input n425_14;
input tx_valid;
input spi_cs_d;
input [7:0] data_send;
output rx_valid;
output CS_Det;
output w_SPI_MISO_Mux;
output [7:0] data_recv;
wire n118_20;
wire n118_21;
wire n118_22;
wire n118_23;
wire n76_3;
wire n33_4;
wire n32_4;
wire n121_5;
wire n120_5;
wire r_SPI_MISO_Bit_8;
wire CS_Cnt_1_16;
wire n38_7;
wire n38_9;
wire r_RX_Done_12;
wire n17_8;
wire n17_10;
wire n18_12;
wire n19_13;
wire r2_RX_Done;
wire r3_RX_Done;
wire r_SPI_MISO_Bit;
wire r_Preload_MISO;
wire r_RX_Done;
wire n118_25;
wire n118_27;
wire n118_29;
wire n116_6;
wire n34_6;
wire n122_7;
wire [2:0] r_RX_Bit_Count;
wire [7:0] r_RX_Byte;
wire [6:0] r_Temp_RX_Byte;
wire [7:0] r_TX_Byte;
wire [2:0] r_TX_Bit_Count;
wire [2:0] CS_Cnt;
wire VCC;
wire GND;
  LUT3 n118_s24 (
    .F(n118_20),
    .I0(r_TX_Byte[0]),
    .I1(r_TX_Byte[1]),
    .I2(r_TX_Bit_Count[0]) 
);
defparam n118_s24.INIT=8'hCA;
  LUT3 n118_s25 (
    .F(n118_21),
    .I0(r_TX_Byte[2]),
    .I1(r_TX_Byte[3]),
    .I2(r_TX_Bit_Count[0]) 
);
defparam n118_s25.INIT=8'hCA;
  LUT3 n118_s26 (
    .F(n118_22),
    .I0(r_TX_Byte[4]),
    .I1(r_TX_Byte[5]),
    .I2(r_TX_Bit_Count[0]) 
);
defparam n118_s26.INIT=8'hCA;
  LUT3 n118_s27 (
    .F(n118_23),
    .I0(r_TX_Byte[6]),
    .I1(r_TX_Byte[7]),
    .I2(r_TX_Bit_Count[0]) 
);
defparam n118_s27.INIT=8'hCA;
  LUT3 CS_Det_s3 (
    .F(CS_Det),
    .I0(CS_Cnt[0]),
    .I1(CS_Cnt[1]),
    .I2(CS_Cnt[2]) 
);
defparam CS_Det_s3.INIT=8'h80;
  LUT2 n76_s0 (
    .F(n76_3),
    .I0(r3_RX_Done),
    .I1(r2_RX_Done) 
);
defparam n76_s0.INIT=4'h4;
  LUT3 w_SPI_MISO_Mux_s0 (
    .F(w_SPI_MISO_Mux),
    .I0(r_TX_Byte[7]),
    .I1(r_SPI_MISO_Bit),
    .I2(r_Preload_MISO) 
);
defparam w_SPI_MISO_Mux_s0.INIT=8'hAC;
  LUT2 n33_s0 (
    .F(n33_4),
    .I0(r_RX_Bit_Count[0]),
    .I1(r_RX_Bit_Count[1]) 
);
defparam n33_s0.INIT=4'h6;
  LUT3 n32_s0 (
    .F(n32_4),
    .I0(r_RX_Bit_Count[0]),
    .I1(r_RX_Bit_Count[1]),
    .I2(r_RX_Bit_Count[2]) 
);
defparam n32_s0.INIT=8'h78;
  LUT2 n121_s0 (
    .F(n121_5),
    .I0(r_TX_Bit_Count[0]),
    .I1(r_TX_Bit_Count[1]) 
);
defparam n121_s0.INIT=4'h9;
  LUT3 n120_s0 (
    .F(n120_5),
    .I0(r_TX_Bit_Count[0]),
    .I1(r_TX_Bit_Count[1]),
    .I2(r_TX_Bit_Count[2]) 
);
defparam n120_s0.INIT=8'hE1;
  LUT3 r_SPI_MISO_Bit_s3 (
    .F(r_SPI_MISO_Bit_8),
    .I0(CS_Cnt[0]),
    .I1(CS_Cnt[1]),
    .I2(CS_Cnt[2]) 
);
defparam r_SPI_MISO_Bit_s3.INIT=8'h7F;
  LUT4 CS_Cnt_1_s6 (
    .F(CS_Cnt_1_16),
    .I0(CS_Cnt[1]),
    .I1(CS_Cnt[0]),
    .I2(spi_cs_d),
    .I3(CS_Cnt[2]) 
);
defparam CS_Cnt_1_s6.INIT=16'h7FFF;
  LUT3 n38_s3 (
    .F(n38_7),
    .I0(n38_9),
    .I1(r_RX_Done_12),
    .I2(r_RX_Done) 
);
defparam n38_s3.INIT=8'hBA;
  LUT3 n38_s4 (
    .F(n38_9),
    .I0(r_RX_Bit_Count[0]),
    .I1(r_RX_Bit_Count[1]),
    .I2(r_RX_Bit_Count[2]) 
);
defparam n38_s4.INIT=8'h80;
  LUT3 r_RX_Done_s5 (
    .F(r_RX_Done_12),
    .I0(r_RX_Bit_Count[0]),
    .I1(r_RX_Bit_Count[1]),
    .I2(r_RX_Bit_Count[2]) 
);
defparam r_RX_Done_s5.INIT=8'h84;
  LUT2 n17_s3 (
    .F(n17_8),
    .I0(CS_Cnt_1_16),
    .I1(n17_10) 
);
defparam n17_s3.INIT=4'hD;
  LUT4 n17_s4 (
    .F(n17_10),
    .I0(CS_Cnt[1]),
    .I1(CS_Cnt[0]),
    .I2(spi_cs_d),
    .I3(CS_Cnt[2]) 
);
defparam n17_s4.INIT=16'h7080;
  LUT4 n18_s5 (
    .F(n18_12),
    .I0(CS_Cnt_1_16),
    .I1(CS_Cnt[1]),
    .I2(CS_Cnt[0]),
    .I3(spi_cs_d) 
);
defparam n18_s5.INIT=16'h7D55;
  LUT3 n19_s6 (
    .F(n19_13),
    .I0(CS_Cnt_1_16),
    .I1(CS_Cnt[0]),
    .I2(spi_cs_d) 
);
defparam n19_s6.INIT=8'h75;
  DFFC r_RX_Bit_Count_2_s0 (
    .Q(r_RX_Bit_Count[2]),
    .D(n32_4),
    .CLK(spi_sclk_d),
    .CLEAR(CS_Det) 
